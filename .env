# Ollama 配置
#OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_BASE_URL=https://ollamaapi.nokiafz.asia/
#OLLAMA_BASE_URL=https://immediate-defines-stays-layout.trycloudflare.com
#OLLAMA_BASE_URL=http://ollama.nokiafz.asia/
OLLAMA_MODEL=qwen3:4b # 轻量级模型，速度更快
#OLLAMA_MODEL=qwen3:8b # 轻量级模型，速度更快

# OMLX 配置（Qwen3.5-4B-OptiQ-4bit 模型）
# 本地 OMLX 服务配置
OMLX_BASE_URL=http://localhost:8000/v1
#OMLX_BASE_URL=http://localhost:8000/v1
#OMLX_MODEL=Qwen3.5-4B-OptiQ-4bit  # 与实际加载的模型名一致
OMLX_MODEL=Qwen3.5-9B-MLX-4bit  # 与实际加载的模型名一致
OMLX_API_KEY=666666  # 本地服务不需要 API Key

# AI 服务选择：true=使用 OMLX，False=使用Ollama
USE_OMLX_FOR_CHATBOT=true
# Flask 配置
FLASK_ENV=development
SECRET_KEY=your-secret-key-here

# MySQL 数据库配置（全局配置，所有数据库共用）
USE_MYSQL=true
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=12345678
MYSQL_CHARSET=utf8mb4

# 各个业务数据库名称（可选，默认使用独立数据库）
KNOWLEDGE_BASE_DB=knowledge_base
AUTH_DB=auth_system
SCHEDULE_DB=schedule

# 日志配置
# 日志级别：ERROR / WARNING / INFO / DEBUG
# ERROR: 只输出错误日志
# WARNING: 输出错误和警告日志
# INFO: 输出错误、警告和信息日志
# DEBUG: 输出所有级别日志（包括调试信息）
LOG_LEVEL=WARNING

# 是否输出到控制台（默认：True）
LOG_TO_CONSOLE=True

# 是否输出到文件（默认：True）
LOG_TO_FILE=True

# 日志格式（可选，默认格式：'%(asctime)s | %(levelname)-8s | %(name)-40s | %(message)s'）
# LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# 日期格式（可选）
# LOG_DATE_FORMAT=%Y/%m/%d %H:%M:%S