[run]
# 要测量覆盖率的源文件
source = .
omit =
    # 忽略虚拟环境
    .venv/*
    venv/*
    # 忽略测试文件本身
    test/*
    */test/*
    # 忽略构建和分发目录
    build/*
    dist/*
    *.egg-info/*
    # 忽略第三方库
    omlx/*
    # 忽略配置文件
    setup.py
    app.spec
    # 忽略迁移脚本
    scripts/*
    # 忽略工具脚本
    utils/cleanup_thread.py
    utils/demo_generator.py
    utils/demo_validator.py
    # 忽略前端代码
    frontend/*
    # 忽略文档
    docs/*
    *.md
    # 忽略SQL文件
    sql/*
    # 忽略静态资源
    static/*
    templates/*
    # 忽略日志和备份
    logs/*
    backups/*
    downloads/*
    tmp/*
    uploads/*
    # 忽略数据库文件
    *.db
    # 忽略排班模块（复杂业务逻辑，单独测试）
    routes/排班/*
    # 忽略AI相关模块（需要外部服务）
    utils/ollama_client.py
    utils/chatbot_core.py
    # 忽略部署助手
    utils/deploy_helper.py
    # 忽略文档处理（需要Office依赖）
    utils/document_processor.py
    utils/document_formatter.py
    utils/document_parser.py
    utils/word_to_excel.py
    utils/excel_to_word_core.py

[report]
# 排除某些模式
exclude_lines =
    # 必须有 pragma: no cover 注释才会被排除
    pragma: no cover
    
    # 抽象方法
    def __repr__
    raise AssertionError
    raise NotImplementedError
    
    # 调试代码
    if __name__ == .__main__.:
    
    # 类型检查
    if TYPE_CHECKING:
    
    # Python 版本检查
    if sys.version_info
    if platform.system

# 显示覆盖率阈值
# 注意：CI环境中使用 --no-cov-on-fail 参数覆盖此设置
# 设置为0表示不强制要求最低覆盖率，仅作为参考
fail_under = 0

# 按文件排序显示
sort = Cover

# 显示缺失的行号
show_missing = True

[html]
# HTML 报告输出目录
directory = htmlcov

# HTML 报告标题
title = Coverage Report
